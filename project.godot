; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="infinity kingdom"
run/main_scene="res://app_entry.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

AccessoryManager="*res://systems/accessories/accessory_manager.gd"
RunDirector="*res://systems/run/run_director.gd"
StartupContext="*res://systems/run/startup_context.gd"
Feedback="*res://systems/feedback/feedback_manager.gd"
Music="*res://audio/music_manager.gd"
Sfx="*res://audio/sfx_manager.gd"
UISettings="*res://systems/ui/ui_settings.gd"
UIText="*res://systems/ui/ui_text.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

