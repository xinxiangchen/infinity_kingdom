; Engine configuration file.
; It is best edited using the editor UI when possible.

config_version=5

[application]

config/name="CPP Coursework Demo"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.3")

[native_extensions]

paths=["res://coursework_extension.gdextension"]

[rendering]

textures/vram_compression/import_etc2_astc=true
